# Environment Configuration Template
# Copy this file to .env and fill in the actual values

# Environment (dev, staging, prod)
NODE_ENV=dev
ENV=dev

# Development Environment
DEV_BASE_URL=http://localhost:3000
DEV_API_BASE_URL=http://localhost:3000/api
DEV_USERNAME=devuser@example.com
DEV_PASSWORD=DevPass123!

# Staging Environment
STAGING_BASE_URL=https://staging.example.com
STAGING_API_BASE_URL=https://staging.example.com/api
STAGING_USERNAME=staginguser@example.com
STAGING_PASSWORD=StagingPass123!

# Production Environment
PROD_BASE_URL=https://example.com
PROD_API_BASE_URL=https://example.com/api
PROD_USERNAME=produser@example.com
PROD_PASSWORD=ProdPass123!

# Playwright Configuration
BASE_URL=http://localhost:3000
CI=false

# Optional: Context7 API key (for higher limits / managed access)
CONTEXT7_API_KEY=
